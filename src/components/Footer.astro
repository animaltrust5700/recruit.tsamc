---
import { assetUrl, routeUrl } from '../lib/assets';

const instagramUrl = 'https://www.instagram.com/tokorozawa.sakura.amc/';
---

<footer class="p-footer">
  <div class="p-footer__inner">
    <div class="p-footer__brand">
      <a href={routeUrl('/')} class="p-footer__logo" aria-label="所沢さくら動物医療センター 採用サイト">
        <img
          class="p-footer__logo-img"
          src={assetUrl('/logo-horizontal.svg')}
          width="386"
          height="60"
          alt="所沢さくら動物医療センター 採用サイト"
          decoding="async"
        />
      </a>
    </div>

    <div class="p-footer__info has-2-xs-font-size" data-layout="-fluid-typography">
      <p class="p-footer__address">〒359-1125 埼玉県所沢市南住吉21-46</p>
      <p class="p-footer__meta">
        <a class="p-footer__tel" href="tel:0429979031">
          <svg class="p-footer__tel-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"></path>
          </svg>
          <span>04-2997-9031</span>
        </a>
        <span class="p-footer__meta-sep" aria-hidden="true">／</span>
        <span class="p-footer__hours">診療時間 9:00-12:00 / 16:00-20:00</span>
        <span class="p-footer__meta-sep" aria-hidden="true">／</span>
        <span class="p-footer__holiday">休診日 日曜・祝日</span>
      </p>
    </div>

    <div class="p-footer__sns">
      <a
        class="p-footer__sns-link"
        href={instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
      </a>
    </div>
  </div>

  <div class="p-footer__bottom has-2-xs-font-size" data-layout="-fluid-typography">
    <span>&copy; 所沢さくら動物医療センター All Rights Reserved.</span>
  </div>
</footer>
